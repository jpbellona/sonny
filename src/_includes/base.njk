<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{% if title %}{{ title }} | {% endif %}{{ site.title }}</title>
  <meta name="description" content="{{ site.description }}" />

  <!-- Open Graph -->
  <meta property="og:title" content="{% if title %}{{ title }} | {% endif %}{{ site.title }}" />
  <meta property="og:description" content="{{ site.description }}" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="{{ site.url }}" />

  <link rel="stylesheet" href="/assets/css/style.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

  {% if site.gaId %}
  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id={{ site.gaId }}"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', '{{ site.gaId }}');
  </script>
  {% endif %}
</head>
<body>
  <header>
    <a href="/" class="site-title">{{ site.title }}</a>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer>
    <p><a href="/" class="footer-title">{{ site.title }}</a>, produced by <a href="https://jpbellona.com">Jon Bellona</a></p>
    <div class="social-links">
      <a href="https://www.instagram.com/sonny_c_and_the_billionaires/" title="Instagram" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
      <a href="https://open.spotify.com/artist/1pwr4V6Kego7e1y0wufCAN?si=LVDrgibXSByqx9QgNl78sw" title="Spotify" aria-label="Spotify"><i class="fab fa-spotify"></i></a>
    </div>
  </footer>
</body>
</html>
